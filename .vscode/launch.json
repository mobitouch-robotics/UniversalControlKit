{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Application",
            "type": "debugpy",
            "request": "launch",
            "module": "src",
            "windows": {
                "python": "${workspaceFolder}/.venv/Scripts/python.exe"
            },
            "linux": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "osx": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "env": {
                "UI": "qt"
            },
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Setup Python Environment"
        },
        {
            "name": "Build and Run Flatpak",
            "type": "node-terminal",
            "request": "launch",
            "command": "flatpak run net.mobitouch.Robots",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Flatpak"
        }
    ]
}
